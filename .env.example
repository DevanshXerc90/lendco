# Copy to .env and fill in what you have. Everything has a working fallback,
# so the system runs end-to-end even with this file empty.

# --- LLM reasoning (optional). Without it, a deterministic planner is used. ---
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8

# --- Embeddings backend: "tfidf" (default, no deps) or "sentence-transformers" ---
EMBEDDINGS_BACKEND=tfidf

# --- Voice backends ---
# STT_BACKEND: "whisper" (faster-whisper) or "text" (typed input)
STT_BACKEND=text
# TTS_BACKEND: "pyttsx3" (spoken) or "print" (text only)
TTS_BACKEND=print
WHISPER_MODEL=base.en

# --- Mock platform service base URLs (independent services) ---
CRM_URL=http://127.0.0.1:8101
PAYMENTS_URL=http://127.0.0.1:8102
SUPPORT_URL=http://127.0.0.1:8103
KNOWLEDGE_URL=http://127.0.0.1:8104
WORKFLOW_URL=http://127.0.0.1:8105
